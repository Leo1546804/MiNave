<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_app"
    tools:context=".MantenimientoFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Cabecera de la pantalla con tipografía destacada -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:text="Mantenimientos"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"/>

        <!-- Contenedor de lista con scroll optimizado y padding inferior para no ocultar el último item tras el FAB -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_mantenimientos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingBottom="88dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_mantenimiento" />

        <LinearLayout
            android:id="@+id/layoutVacioMantenimiento"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingBottom="88dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/mantenimiento"
                app:tint="@color/azul_principal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No hay mantenimientos"
                android:textColor="@color/negro_texto"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="¡Toca el botón + para registrar uno!"
                android:textColor="@color/gris_subtitulo"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Acción principal: Registrar nuevo servicio de mantenimiento -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_agregar_mantenimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Nuevo Mantenimiento"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/azul_principal"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
