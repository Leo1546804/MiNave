<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fondo_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/back"
            app:tint="@color/azul_principal"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/txtTituloMantenimiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Mantenimiento"
            android:textColor="@color/azul_principal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="48dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detalles Técnicos"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/negro_texto"
                    android:layout_marginBottom="20dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/diseñoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Tipo de Mantenimiento"
                    app:startIconDrawable="@android:drawable/ic_menu_manage">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoTipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/negro_texto"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/diseñoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Fecha de Servicio"
                    app:startIconDrawable="@android:drawable/ic_menu_my_calendar">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoFecha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/negro_texto"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/diseñoInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Kilometraje">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/campoKilometraje"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/negro_texto"
                            android:inputType="number"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/diseñoInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Próximo KM">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/campoProximoKm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/negro_texto"
                            android:inputType="number"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/diseñoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Costo Total"
                    app:prefixText="S/ ">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoCosto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/negro_texto"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/diseñoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Taller / Lugar"
                    app:startIconDrawable="@android:drawable/ic_menu_mapmode">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoTaller"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/negro_texto"
                        android:inputType="textCapWords"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/diseñoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:hint="Observaciones">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoObservaciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/negro_texto"
                        android:inputType="textCapSentences"
                        android:gravity="top"
                        android:lines="3"/>
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnGuardarMantenimiento"
                    style="@style/diseñoBoton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardar Registro"
                    android:textAllCaps="false"
                    android:letterSpacing="0.05"
                    android:elevation="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>
</LinearLayout>
