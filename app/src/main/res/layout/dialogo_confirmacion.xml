<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <View
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:background="#E2E8F0"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvTituloDialogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmar acción"
            android:textColor="@color/azul_principal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvMensajeDialogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="¿Estás seguro de realizar esta operación?"
            android:textColor="@color/gris_subtitulo"
            android:textSize="15sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarDialogo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="No, volver"
                android:textColor="@color/gris_subtitulo"
                android:backgroundTint="@color/gris_boton_secundario"
                android:textAllCaps="false"
                android:letterSpacing="0"
                app:cornerRadius="14dp"
                android:paddingVertical="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmarDialogo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Sí, eliminar"
                android:textColor="@color/white"
                android:backgroundTint="#EF4444"
                android:textAllCaps="false"
                android:letterSpacing="0"
                app:cornerRadius="14dp"
                android:paddingVertical="12dp"
                android:elevation="2dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>